##############################################################################
#
#   Gradle start up script for POSIX generated by Gradle.
#
#   Important for running:
#
#       (1) You need a POSIX-compliant shell to run this script.
#
#   Optional environment variables:
#
#       GRADLE_JAVA_OPTS
#               (optional) Java command line options used to run Gradle.
#
#       JAVA_HOME
#               (optional) Directory of Java installation to be used.
#
#       GRADLE_EXIT_CONSOLE
#               (optional) Set to '1' to force Gradle to exit with a
#               non-zero exit code when the script has an error.
#
#               Note: Gradle will always exit with an appropriate exit
#               code when running interactively.
#
#       GRADLE_USER_HOME
#               (optional) Directory for Gradle user data, instead of ~/.gradle.
#
##############################################################################

# Attempt to set APP_HOME
# Resolve links: $0 may be a link
APP_HOME=$(cd "$(dirname "$0")" && pwd)
while [ -h "$APP_HOME/$APP_NAME" ]; do
    ls=$(ls -ld "$APP_HOME/$APP_NAME")
    link=$(expr "$ls" : '.*-> \(.*\)$')
    if expr "$link" : '/.*' > /dev/null; then
        APP_HOME="$link"
    else
        APP_HOME=$(dirname "$APP_HOME")"/$link"
    fi
done

# Set APP_BASE_NAME to the name of this script
APP_BASE_NAME=$(basename "$0")

# Use the maximum available, or set MAX_FD != -1 to use that value.
MAX_FD="maximum"

warn () {
    echo "$*"
}

die () {
    echo
    echo "$*"
    echo
    exit 1
}

# OS specific support (must be 'true' or 'false').
cygwin=false
msys=false
darwin=false
nonstop=false
case "$(uname)" in
  CYGWIN* )
    cygwin=true
    ;;
  Darwin* )
    darwin=true
    ;;
  MINGW* | MSYS* )
    msys=true
    ;;
  NONSTOP* )
    nonstop=true
    ;;
esac

CLASSPATH=$APP_HOME/gradle/wrapper/gradle-wrapper.jar

# Determine the Java command to use to start the JVM.
if [ -n "$JAVA_HOME" ] ; then
    if [ -x "$JAVA_HOME/jre/sh/java" ] ; then
        # IBM's JDK on AIX uses strange locations for the executables
        JAVACMD="$JAVA_HOME/jre/sh/java"
    else
        JAVACMD="$JAVA_HOME/bin/java"
    fi
    if [ ! -x "$JAVACMD" ] ; then
        die "ERROR: JAVA_HOME is set to an invalid directory: $JAVA_HOME

Please set the JAVA_HOME variable in your environment to match the
location of your Java installation."
    fi
else
    JAVACMD="java"
    command -v java >/dev/null 2>&1 || die "ERROR: JAVA_HOME is not set and no 'java' command could be found in your PATH.

Please set the JAVA_HOME variable in your environment to match the
location of your Java installation."
fi

# Increase the maximum file descriptors if we can.
if [ "$cygwin" = "false" -a "$darwin" = "false" -a "$nonstop" = "false" ] ; then
    MAX_FD_LIMIT=$(ulimit -H -n)
    if [ $? -eq 0 ] ; then
        if [ "$MAX_FD" = "maximum" -o "$MAX_FD" = "max" ] ; then
            MAX_FD="$MAX_FD_LIMIT"
        fi
        ulimit -n "$MAX_FD"
        if [ $? -ne 0 ] ; then
            warn "Could not set maximum file descriptor limit: $MAX_FD"
        fi
    else
        warn "Could not query maximum file descriptor limit: $MAX_FD_LIMIT"
    fi
fi

# For Darwin, add options to specify how the application appears in the dock
if $darwin; then
    GRADLE_OPTS="$GRADLE_OPTS \"-Xdock:name=$APP_BASE_NAME\""
fi

# For Cygwin or MSYS, switch paths to Windows format before running java
if [ "$cygwin" = "true" -o "$msys" = "true" ] ; then
    APP_HOME=$(cygpath --path --mixed "$APP_HOME")
    CLASSPATH=$(cygpath --path --mixed "$CLASSPATH")
    JAVACMD=$(cygpath --unix "$JAVACMD")

    # We build the pattern for arguments to be converted via cygpath
    ROOTDIRS_RAW=$(cygpath --path --mixed --list-sigwin-codes)
    ROOTDIRS="$(echo "$ROOTDIRS_RAW" | sed -e 's/\\\$/\\\\\\$/g' -e 's/\//\\\//g' -e 's/|/\\|/g')"
    WINDOWS_PATHS_PATTERN="(^|;)($ROOTDIRS):"
    case "(;)$*" in
      *";--help"|*";-?"*)
        SHORT_OPTS="true";;
    esac

    if [ "$SHORT_OPTS" = "true" ] ; then
        # shellcheck disable=SC2016
        printf 'Usage: %s [OPTION]... [ARG]...\n' "$APP_BASE_NAME"
        printf '  -?,-h,--help         show this help and exit\n'
        printf '  -v,--version        show version and exit\n'
        printf '  -q,--quiet          log errors only\n'
        printf '  -w,--warn           set log level to warn\n'
        printf '  -i,--info           set log level to info\n'
        printf '  -d,--debug          log in debug mode (includes normal stacktrace)\n'
        printf '  --stacktrace        output the full stacktrace for all exceptions\n'
        printf '  --no-daemon         do not use the Gradle daemon for the build\n'
        printf '  --foreground        do not attempt to use the daemon if it is running\n'
        printf '                      start in the foreground\n'
        printf '  -D,--system-prop    set JVM system property of the form key=value\n'
        printf '  -I,--init-script    specify initialization script\n'
        printf '  -b,--build-file     set build file\n'
        printf '  -c,--settings-file  set settings file\n'
        printf '  -g,--gradle-user-home   sets the gradle user home directory\n'
        printf '  -p,--project-dir    set project directory\n'
        printf '  -u,--no-search-upward  dont search in parent directories\n'
        printf '  --include-build     include the build in the composite\n'
        printf '  --offline           execute the build without accessing network resources\n'
        printf '  --refresh-dependencies  refresh the state of dependencies\n'
        printf '  --dry-run           run the build with all task actions disabled\n'
        printf '  --write-locks       write the state of dependency locks for the subprojects\n'
        printf '  --no-write-locks    dont write the state of dependency locks for the subprojects\n'
        printf '  --update-locks      update the state of dependency locks for the subprojects\n'
        printf '  --no-configuration-cache  do not use the configuration cache for the build\n'
        printf '  --configuration-cache   use the configuration cache for the build\n'
        printf '  --no-build-cache    do not use the build cache\n'
        printf '  --build-cache       use the build cache\n'
        printf '  --continue          continue task execution after a failure\n'
        printf '  --no-parallel       do not use parallel builds\n'
        printf '  --parallel          use parallel builds\n'
        printf '  --no-configure-on-demand  do not use configure on demand\n'
        printf '  --configure-on-demand  use configure on demand\n'
        printf '  --no-scan           do not create a build scan, even if the plugin is applied\n'
        printf '  --scan              create a build scan\n'
        printf '\n'
        printf 'Environment variables:\n'
        printf '  GRADLE_JAVA_OPTS        (optional) JVM arguments for Gradle\n'
        printf '  JAVA_HOME              (optional) Location of Java installation\n'
        printf '  GRADLE_EXIT_CONSOLE    (optional) If non-empty, exit code of the script is\n'
        printf '                          used instead of that of Gradle.\n'
        exit 0
    fi
fi

# Collect all arguments for the java command, following the getopt shell
# parsing rules (short options can be grouped, long options can be separated
# by space or =).
#
# However, we do NOT want to touch the arguments that will be passed to
# the actual command. We will leave those intact.
APP_ARGS=

while true ; do
    case "$1" in
        -D*=*)
            APP_ARGS="$APP_ARGS '$1'"
            shift
            ;;
        -D*)
            warn "Invalid system property argument: $1"
            APP_ARGS="$APP_ARGS '$1'"
            shift
            ;;
        --system-prop)
            APP_ARGS="$APP_ARGS '-D$2'"
            shift 2
            ;;
        -D)
            warn "Invalid system property argument: $1"
            APP_ARGS="$APP_ARGS '-D$2'"
            shift 2
            ;;
        --init-script|-I)
            APP_ARGS="$APP_ARGS '-I=$2'"
            shift 2
            ;;
        --build-file|-b)
            APP_ARGS="$APP_ARGS '-b=$2'"
            shift 2
            ;;
        --settings-file|-c)
            APP_ARGS="$APP_ARGS '-c=$2'"
            shift 2
            ;;
        --gradle-user-home|-g)
            APP_ARGS="$APP_ARGS '-g=$2'"
            shift 2
            ;;
        --project-dir|-p)
            APP_ARGS="$APP_ARGS '-p=$2'"
            shift 2
            ;;
        --no-search-upward|-u)
            APP_ARGS="$APP_ARGS '-u'"
            shift
            ;;
        --include-build)
            APP_ARGS="$APP_ARGS '--include-build=$2'"
            shift 2
            ;;
        --no-daemon)
            APP_ARGS="$APP_ARGS '--no-daemon'"
            shift
            ;;
        --foreground)
            APP_ARGS="$APP_ARGS '--foreground'"
            shift
            ;;
        -v|--version)
            echo "Gradle 8.5"
            exit 0
            ;;
        --)
            shift
            break
            ;;
        *)
            break
            ;;
    esac
done

# Split up the JVM_OPTS into an array, following the shell quoting and
# splitting rules, and then add them to the java_args array
JVM_OPTS_ARRAY=
eval set -- "$JVM_OPTS"
for arg do
    JVM_OPTS_ARRAY="$JVM_OPTS_ARRAY '$arg'"
done

# Split up the DEFAULT_JVM_OPTS into an array, following the shell quoting
# and splitting rules, and then add them to the java_args array
eval set -- "$DEFAULT_JVM_OPTS"
for arg do
    DEFAULT_JVM_OPTS_ARRAY="$DEFAULT_JVM_OPTS_ARRAY '$arg'"
done

# Escape application args
save () {
    for i do printf %s\\n "$i" | sed "s/'/'\\\\''/g;1s/^/'/;\$s/\$/' \\\\/"; done
    echo " "
}
APP_ARGS=$(save "$@")

# Collect all arguments for the java command, following the shell quoting
# and substitution rules
eval set -- $DEFAULT_JVM_OPTS_ARRAY $JVM_OPTS_ARRAY $GRADLE_OPTS "\"-Dorg.gradle.appname=$APP_BASE_NAME\"" -classpath "\"$CLASSPATH\"" org.gradle.wrapper.GradleWrapperMain "$APP_ARGS"

# Execute Gradle
"$JAVACMD" "$@"

# Exit with the status code of Gradle
exit $?